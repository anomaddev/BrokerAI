---
# Example Authelia configuration for BrokerAI OIDC.
# Mount this file into your Authelia container and customize secrets, domains, and users.

theme: dark
server:
  address: 'tcp://:9091'

log:
  level: info

identity_validation:
  reset_password:
    jwt_secret: replace-with-long-random-string

authentication_backend:
  file:
    path: /config/users_database.yml

access_control:
  default_policy: deny
  rules:
    - domain: brokerai.example.com
      policy: one_factor

session:
  secret: replace-with-long-random-string
  cookies:
    - domain: brokerai.example.com
      authelia_url: https://auth.brokerai.example.com

storage:
  encryption_key: replace-with-long-random-string
  local:
    path: /config/db.sqlite3

notifier:
  filesystem:
    filename: /config/notification.txt

identity_providers:
  oidc:
    hmac_secret: replace-with-long-random-string
    jwks:
      - key: |
          -----BEGIN PRIVATE KEY-----
          replace-with-generated-private-key
          -----END PRIVATE KEY-----
    clients:
      - client_id: brokerai
        client_name: BrokerAI
        client_secret: replace-with-client-secret
        public: false
        authorization_policy: one_factor
        redirect_uris:
          - https://brokerai.example.com/api/auth/oidc/callback
        scopes:
          - openid
          - profile
          - email
        grant_types:
          - authorization_code
        response_types:
          - code
        token_endpoint_auth_method: client_secret_basic
