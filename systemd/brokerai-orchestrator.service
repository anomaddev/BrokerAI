[Unit]
Description=BrokerAI Orchestrator
After=network-online.target docker.service
Wants=network-online.target docker.service

[Service]
Type=simple
User=brokerai
Group=brokerai
WorkingDirectory=/opt/brokerai
EnvironmentFile=/etc/brokerai/config.env
ExecStart=/opt/brokerai/venv/bin/brokerai run orchestrator
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
