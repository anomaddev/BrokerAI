BROKERAI_SECRET_KEY=
BROKERAI_AUTH_MODE=builtin
BROKERAI_WEB_PORT=1989
# Bind address for uvicorn. Use 127.0.0.1 when Caddy terminates TLS in front.
# BROKERAI_WEB_BIND=0.0.0.0
# Public hostname for LXC TLS (installs host Caddy when set).
# Can also be set later in Settings → System → Public domains (HTTPS):
# BROKERAI_DOMAIN=brokerai.example.com
# Optional second hostname for public Kong + Studio (same host Caddy; do not use
# deploy/supabase docker-compose.caddy.yml — it conflicts on :80/:443):
# BROKERAI_SUPABASE_DOMAIN=supabase.example.com
# When BROKERAI_SUPABASE_DOMAIN is set, install/UI sets BROKERAI_SUPABASE_URL to
# https://<that-host> so browser Realtime/signed URLs match the public edge.
BROKERAI_LOG_LEVEL=INFO
# Secretary mode (default): secretary + broker + researcher
BROKERAI_ENABLED_BOTS=secretary,broker,researcher
BROKERAI_AUTO_UPDATE=true
BROKERAI_REPO=https://github.com/anomaddev/BrokerAI

# Postgres via self-hosted Supabase (see deploy/supabase/BROKERAI.md)
BROKERAI_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/postgres
# Kong URL: loopback for private installs; https://<BROKERAI_SUPABASE_DOMAIN> when public.
BROKERAI_SUPABASE_URL=http://127.0.0.1:8000
BROKERAI_SUPABASE_ANON_KEY=
BROKERAI_SUPABASE_SERVICE_ROLE_KEY=
BROKERAI_SUPABASE_JWT_SECRET=
BROKERAI_USE_POSTGRES=true
# Frontend reads publishable URL/anon key from GET /api/auth/config (not VITE_*).
# Research reports use private Storage bucket research-reports when Supabase is configured.
# Postgres stays on 127.0.0.1:5432 even when Kong/Studio are publicly proxied.

# OANDA account list + summary sync to Postgres (seconds; minimum 60)
BROKERAI_OANDA_ACCOUNT_SYNC_INTERVAL_SECONDS=60

# OANDA exposure health check + stale cursor repair (seconds)
# BROKERAI_OANDA_EXPOSURE_CHECK_INTERVAL_SECONDS=3600
# BROKERAI_OANDA_CURSOR_STALE_THRESHOLD_SECONDS=3600

# Broker event persistence (Phase 3)
# BROKERAI_BROKER_EVENTS_BULK_BATCH_SIZE=500
# BROKERAI_BROKER_EVENTS_RETENTION_ENABLED=true
# BROKERAI_BROKER_EVENTS_LOW_VALUE_RETENTION_DAYS=90

# Local dev: runtime state under ./data (see scripts/dev.sh)
# BROKERAI_DATA_DIR=data
# BROKERAI_LOG_DIR=logs

# Deny all gated LLM calls (AI Strategy decisions + spend-gated research path)
# BROKERAI_LLM_KILL_SWITCH=false

# Postgres logical dumps (scripts/backup-postgres.sh + systemd timer)
# BROKERAI_BACKUP_DIR=/var/lib/brokerai/backups/postgres
# BROKERAI_BACKUP_RETENTION_DAYS=7

# OIDC auth (see docs/auth/self-hosted-oidc.md)
# BROKERAI_AUTH_MODE=oidc
# BROKERAI_OIDC_ISSUER=https://auth.example.com
# BROKERAI_OIDC_CLIENT_ID=brokerai
# BROKERAI_OIDC_CLIENT_SECRET=
# BROKERAI_OIDC_ALLOWED_SUB=
# BROKERAI_SESSION_COOKIE_SECURE=true

# Update track (Swift Package Manager-style):
#   branch         — latest commit on BROKERAI_BRANCH
#   release        — pinned to BROKERAI_RELEASE tag
#   latest-release — newest GitHub release
#   next-major     — newest release within the installed major version
BROKERAI_UPDATE_TRACK=branch
BROKERAI_BRANCH=main
BROKERAI_RELEASE=
